# NextAuth Configuration
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# User Management
# Generate password hashes using: node -e "console.log(require('bcryptjs').hashSync('YourPassword123', 10))"
USERS_JSON=[{"id":"demo-user-1","username":"demo","passwordHash":"$2a$10$example.hash.here","role":"customer"}]

# File Upload Limits
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.csv,.xlsx,.xls
